# =========================================================================
# Paradise Task Tracker — template environment kantor
# Salin ke ./.env di root, lalu ISI SEMUA nilai bertanda <GANTI>.
# JANGAN commit .env asli (sudah di-ignore). Nama variabel = sesuai Plane CE.
# =========================================================================

# --- Domain / URL (ganti localhost -> domain atau IP LAN kantor) ----------
APP_DOMAIN=paradise.kantor.local
WEB_URL=http://paradise.kantor.local
ADMIN_BASE_URL=http://paradise.kantor.local
SPACE_BASE_URL=http://paradise.kantor.local
CORS_ALLOWED_ORIGINS=http://paradise.kantor.local
SITE_ADDRESS=:80              # Caddy: ganti ke domain utk auto-HTTPS
CERT_EMAIL=                   # isi email utk Let's Encrypt kalau pakai HTTPS

# --- Secrets (WAJIB diganti sebelum prod — lihat SECURITY-CHECKLIST.md) ---
SECRET_KEY=<GANTI-django-secret-64-hex>
LIVE_SERVER_SECRET_KEY=<GANTI-live-secret-64-hex>

# --- PostgreSQL -----------------------------------------------------------
POSTGRES_USER=paradise
POSTGRES_PASSWORD=<GANTI-password-kuat>
POSTGRES_DB=paradise
PGDATA=/var/lib/postgresql/data

# --- Redis ----------------------------------------------------------------
REDIS_HOST=plane-redis
REDIS_PORT=6379

# --- RabbitMQ -------------------------------------------------------------
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=paradise
RABBITMQ_PASSWORD=<GANTI-password-kuat>
RABBITMQ_VHOST=paradise

# --- Storage (MinIO lokal; ganti kredensial default!) ---------------------
USE_MINIO=1
AWS_REGION=
AWS_ACCESS_KEY_ID=<GANTI-minio-access-key>
AWS_SECRET_ACCESS_KEY=<GANTI-minio-secret-key>
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
FILE_SIZE_LIMIT=5242880

# --- Lain-lain ------------------------------------------------------------
API_KEY_RATE_LIMIT=60/minute
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443
